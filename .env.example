# DeepSeek auth token (Bearer token from your browser session)
DEEPSEEK_AUTH_TOKEN=

# Or sign in with your DeepSeek account
DEEPSEEK_EMAIL=
DEEPSEEK_PASSWORD=
DEEPSEEK_SAVE_LOGIN=true
DEEPSEEK_LOGIN_FILE=login.json

# Optional: Cookies from your browser session (for WAF/CSRF)
DEEPSEEK_COOKIES=aws-waf-token=...; ds_session_id=...

# Optional: Cookie refresh support
DEEPSEEK_COOKIE_FILE=cookies.json
DEEPSEEK_COOKIE_REFRESH_COMMAND=

# Optional: Protect this proxy with an API key
# Set this to require clients to pass Bearer <API_KEY>
API_KEY=

# Server port
PORT=9123
